<?xml version="1.0" encoding="UTF-8" ?>
<routes xmlns="http://symfony.com/schema/routing"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://symfony.com/schema/routing https://symfony.com/schema/routing/routing-1.0.xsd">

    <!--
        Loads PHP-attribute Routes from every controller under
        src/Controller/Admin. Shopware 6.6+ uses Symfony PHP attributes; the
        legacy "annotation" loader is kept as an alias by Symfony so this
        resource declaration also works on older 6.5 builds without changes.
    -->
    <import resource="../../Controller/Admin" type="attribute"/>

    <!--
        Wave 7C: storefront controllers (customer-portal invoice download).
        Same attribute-loader pattern as the admin import above.
    -->
    <import resource="../../Storefront/Controller" type="attribute"/>
</routes>
